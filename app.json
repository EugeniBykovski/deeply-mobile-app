{
  "expo": {
    "name": "Deeply",
    "slug": "deeply-mobile",
    "version": "1.0.5",
    "buildNumber": "5",
    "scheme": "deeply",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0c1b1c"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yauhenibykouski.deeply",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#0c1b1c"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.deeply.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-localization",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#0c1b1c"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "362febce-af8a-4c2e-8490-49593ec8f291"
      }
    }
  }
}
